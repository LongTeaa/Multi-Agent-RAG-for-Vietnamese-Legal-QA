# === Gemini API Keys (Multi-Project Key Rotation) ===
# Bạn có thể thêm bao nhiêu key tùy thích, hệ thống sẽ tự động xoay vòng.
# Mỗi agent sẽ được ưu tiên bắt đầu bằng một key khác nhau để tối ưu hạn mức.
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# === Model Configuration ===
# gemini-2.5-flash: chất lượng cao nhất cho pháp lý
# gemini-2.0-flash: dự phòng hoặc dùng cho dev
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1
# Model dự phòng nếu model chính lỗi
FALLBACK_MODEL=gemini-2.0-flash

# === Vector DB ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
COLLECTION_NAME=vietnamese_legal_chunks

# === Web Search (Tavily) ===
TAVILY_API_KEY=

# === Embedding Config ===
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu
HF_TOKEN=

# === App Configuration ===
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_RETRIES=3
TOP_K_DOCUMENTS=5
