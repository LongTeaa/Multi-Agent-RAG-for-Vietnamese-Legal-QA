# =====================================
# .env.example – Copy sang .env và điền giá trị thực
# =====================================

# === LLM APIs ===
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=sk-ant-...        # (tùy chọn, nếu dùng Claude)
OPENAI_API_KEY=sk-...               # (tùy chọn, nếu dùng GPT-4o)

# === Vector DB (Qdrant) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                     # Để trống nếu chạy local

# === Web Search ===
TAVILY_API_KEY=tvly-...             # Lấy tại https://tavily.com

# === App Configuration ===
ENVIRONMENT=development             # development | production
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# === RAG Config ===
MAX_RETRIES=3                       # Số lần tối đa Hallucination Grader retry
TOP_K_DOCUMENTS=5                   # Số tài liệu truy xuất từ Qdrant

# === Model Config ===
# Options: gemini-2.0-flash, gemini-1.5-pro, claude-3-5-sonnet-20241022, gpt-4o
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0                   # Temperature=0 để kết quả deterministic

# intfloat/multilingual-e5-large-instruct hoặc BAAI/bge-m3
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
EMBEDDING_DEVICE=cpu                # cpu | cuda (nếu có GPU)

# === Qdrant Collection ===
COLLECTION_NAME=vietnamese_legal_chunks
